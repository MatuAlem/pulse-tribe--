# ==============================
# PULSE TRIBE — Environment Variables
# Copy this file to .env and fill in your values
# ==============================

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/pulse_tribe
# For MongoDB Atlas (cloud):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/pulse_tribe

# JWT Secret (change this to a long random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d

# Anthropic AI (for AI Chat feature)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# File Upload (optional)
MAX_FILE_SIZE=5242880
